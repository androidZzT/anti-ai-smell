{
  "version": "0.1.0",
  "name": "anti-ai-smell",
  "description": "中文 AI 味词汇 → 人话 映射表。收录 AI 生成中文里高频的生造词、翻译腔、戏剧化、宏大官腔，给出母语者真正会说的替代。",
  "categories": [
    {
      "id": "coined",
      "title": "生造词",
      "desc": "把一个意思硬缩成一个母语者不这么说的新词。",
      "severity": "soft",
      "words": [
        {"w": "切法", "human": ["这么问", "这个角度", "这么拆"]},
        {"w": "硬货", "human": ["干货", "实料", "真正有用的东西"]},
        {"w": "打法", "human": ["做法", "思路", "怎么搞"]},
        {"w": "换口味", "human": ["换个类型", "换个花样"]},
        {"w": "吃量", "human": ["有没有流量", "受不受欢迎"]}
      ]
    },
    {
      "id": "translationese",
      "title": "翻译腔",
      "desc": "把英文概念硬翻成生硬、字面、母语者不用的中文词。",
      "severity": "soft",
      "words": [
        {"w": "门控", "en": "gate / gating", "human": ["把关", "卡一道", "网关"], "note": "机器学习的 gating（按输入选专家）、电路的门是精确专有词，那种场合可用。"},
        {"w": "横切", "en": "cross-cutting", "human": ["到处都要管的", "贯穿各处的", "通用那部分"]},
        {"w": "能拿走", "en": "takeaway", "human": ["能记住的一点", "真正有用的", "教训"]},
        {"w": "形状是这样", "en": "the shape of it", "human": ["大概是这么回事", "过程是这样"]},
        {"w": "是活的", "en": "is alive", "human": ["没挂", "好好的", "还在正常跑"], "note": "指服务器/进程时。"},
        {"w": "收敛", "en": "converge", "human": ["慢慢定下来", "归到一处", "不再来回变"], "note": "数学、迭代算法里是精确术语，别乱替。"},
        {"w": "消费", "en": "consume", "human": ["调用", "用", "处理"], "note": "指「消费接口 / 消费事件」时。中文「消费」是花钱。"},
        {"w": "暴露", "en": "expose", "human": ["提供", "开放", "对外给出"], "note": "指「暴露一个接口」时。中文「暴露」带负面味。"},
        {"w": "契约", "en": "contract", "human": ["约定", "规范", "说好的格式"]},
        {"w": "鲁棒", "en": "robust", "human": ["稳", "抗造", "扛得住异常"], "note": "音译，读着莫名其妙。"},
        {"w": "一等公民", "en": "first-class citizen", "human": ["原生支持", "天生就能直接用", "摆在头等位置"]},
        {"w": "原语", "en": "primitive", "human": ["最基本的操作", "最小的积木块"]},
        {"w": "心智模型", "en": "mental model", "human": ["脑子里大概怎么理解它", "怎么想这件事"]},
        {"w": "优雅降级", "en": "graceful degradation", "human": ["坏了也别整个崩，留个能用的最小版"]},
        {"w": "面包屑", "en": "breadcrumb", "human": ["线索", "踪迹", "留下的记号"], "note": "UI 里「面包屑导航」是通用词，那种场合可用；当「留线索 / 踪迹」的比喻时换人话。"},
        {"w": "旋钮", "en": "knob / dial", "human": ["设置", "选项", "开关", "参数"], "note": "指软件的设置/参数时。中文「旋钮」是实体旋钮，软件语境属直译。"}
      ]
    },
    {
      "id": "theatrical",
      "title": "戏剧化",
      "desc": "给平淡的事实套上戏剧化、拟人化的形容或金句。",
      "severity": "soft",
      "words": [
        {"w": "理直气壮的谎", "human": ["报告成功、其实失败了"]},
        {"w": "欢快的成功", "human": ["又报了个「成功」"]},
        {"w": "一模一样的病", "human": ["同一类问题", "一样的毛病"]},
        {"w": "最容易的死法", "human": ["最容易翻车的地方"]},
        {"w": "留在桌上", "en": "left on the table", "human": ["白白放着没用", "没利用起来"]}
      ]
    },
    {
      "id": "loaded",
      "title": "带味的字",
      "desc": "带负面或过强暗示的用字，读着不干净。",
      "severity": "soft",
      "words": [
        {"w": "偷师", "human": ["学", "取经"]},
        {"w": "偷凭证", "human": ["窃取凭证", "盗取凭证"], "note": "技术语境用中性的「窃取」。"},
        {"w": "扒黑料", "human": ["翻旧账", "找问题"]}
      ]
    },
    {
      "id": "grandiose",
      "title": "宏大 / 官腔",
      "desc": "拟人化、宏大叙事、营销官腔——最经典的一股 AI 味。",
      "severity": "hard",
      "words": [
        {"w": "长出", "human": ["新增", "多了个", "冒出来"]},
        {"w": "涌现", "human": ["（量大后）冒出没设计过的能力"], "note": "复杂系统、大模型规模效应里是术语，别当万能词。"},
        {"w": "孕育", "human": ["催生出", "带来"]},
        {"w": "催生", "human": ["带来", "促成"]},
        {"w": "应运而生", "human": ["出现了", "有了"]},
        {"w": "赋能", "human": ["帮", "让……能……"]},
        {"w": "不仅仅", "human": ["不只是", "不止"]},
        {"w": "远不止", "human": ["不只是"]},
        {"w": "全方位", "human": ["各方面", "或直接列具体"]},
        {"w": "一站式", "human": ["一处搞定", "或直接说做了什么"]},
        {"w": "开启新篇章", "human": ["删掉，或换成具体时间/事件"]},
        {"w": "迈入新时代", "human": ["删掉，或换成具体变化"]},
        {"w": "绘就蓝图", "human": ["计划", "打算做什么"]},
        {"w": "堪称", "human": ["算是", "可以说是", "或删"]}
      ]
    },
    {
      "id": "filler",
      "title": "套话 / 连接词",
      "desc": "开场白、拐杖词、模糊归因，删掉句子更利落。",
      "severity": "hard",
      "words": [
        {"w": "值得注意的是", "human": ["删掉，直接说"]},
        {"w": "此外", "human": ["删掉，另起一句"]},
        {"w": "综上所述", "human": ["删掉，直接给结论"]},
        {"w": "总而言之", "human": ["删掉"]},
        {"w": "至关重要", "human": ["关键", "重要"]},
        {"w": "深入探讨", "human": ["讨论", "分析"]},
        {"w": "不断演变的格局", "human": ["变化", "趋势"]},
        {"w": "专家认为", "human": ["给出具体来源，或删"]},
        {"w": "诸如此类", "human": ["直接列举"]}
      ]
    }
  ],
  "syntax_patterns": [
    {"id": "em_dash", "title": "破折号滥用", "regex": "——", "hint": "能用逗号或句号就别用破折号，尤其别在「揭示」前甩一个。"},
    {"id": "rhetorical_q", "title": "修辞性设问", "regex": "(根子在哪|问题出在哪|为什么会这样|这意味着什么)[？?]", "hint": "别自问自答，直接陈述。"},
    {"id": "not_only", "title": "否定式排比", "regex": "不仅仅?[^，。]{0,12}(而是|更是|而且)", "hint": "「不仅仅……而是……」，直接说是什么。"},
    {"id": "curly_quote", "title": "弯引号", "regex": "[“”‘’]", "hint": "中文用「」或正常引号，别用英文弯引号。"},
    {"id": "emoji", "title": "emoji 装饰", "regex": "[☀-➿🌀-🫿]", "hint": "对外正文一般不用 emoji 装饰标题/条目。"},
    {"id": "ing_analysis", "title": "-ing 肤浅分析", "regex": "(彰显|凸显|体现|反映|印证)了[^，。]{0,20}(的|其)", "hint": "句尾「彰显了……」式虚假深度，删掉让事实自己说。"}
  ]
}
